// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth tables
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions             Session[]
  accounts             Account[]
  paidExpenses         Expense[]
  airConditioningUsage AirConditioningUsage[]
  categorySplits       CategorySplit[]
  expenseSplits        ExpenseSplit[]

  @@index([isActive])
  @@index([name])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Category {
  id         String   @id @default(cuid())
  name       String   @unique
  splitType  SplitType @default(EQUAL)
  createdAt  DateTime @default(now())

  expenses   Expense[]
  splits     CategorySplit[]
}

model Expense {
  id           String      @id @default(cuid())
  date         DateTime
  amount       Float
  description  String
  categoryId   String
  paidById     String
  monthYear    String      // "2024-03" format
  type         ExpenseType @default(EXPENSE)
  createdAt    DateTime    @default(now())
  
  category     Category @relation(fields: [categoryId], references: [id])
  paidBy       User     @relation(fields: [paidById], references: [id])
  customSplits ExpenseSplit[]
  
  @@index([monthYear])
  @@index([categoryId])
  @@index([paidById])
  @@index([date])
  @@index([monthYear, categoryId])
  @@index([monthYear, paidById])
}

model CipConfiguration {
  id                   String   @id @default(cuid())
  monthYear            String   @unique
  baseCalculationValue Float    // Conv4 - % Tarifa B4A
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  
  tiers                CipTier[]
  
  @@index([monthYear])
}

model CipTier {
  id               String  @id @default(cuid())
  configurationId  String
  minKwh           Float
  maxKwh           Float?  // null for "above X"
  percentage       Float
  
  configuration    CipConfiguration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  
  @@index([configurationId])
}

model AirConditioningUsage {
  id                  String   @id @default(cuid())
  monthYear           String
  userId              String
  airConsumptionKwh   Float    // AC consumption
  totalConsumptionKwh Float    // total apartment consumption
  totalBillAmount     Float    // total energy bill
  kwhUnitPrice        Float    // price per kWh
  totalCipAmount      Float    // total CIP paid
  calculatedAmount    Float    // amount the current user must pay
  cipTierWithoutAir   Float    // CIP tier without AC
  cipTierWithAir      Float    // CIP tier with AC
  createdAt           DateTime @default(now())
  
  user                User     @relation(fields: [userId], references: [id])
  
  @@index([monthYear])
  @@index([userId])
  @@index([monthYear, userId])
}

model MonthlySettlement {
  id        String   @id @default(cuid())
  monthYear String   @unique
  closedAt  DateTime?
  status    SettlementStatus @default(OPEN)
  createdAt DateTime @default(now())
  
  settlements Settlement[]
  
  @@index([monthYear])
  @@index([status])
}

model Settlement {
  id                  String  @id @default(cuid())
  monthlySettlementId String
  fromUserId          String
  toUserId            String
  amount              Float
  
  monthlySettlement   MonthlySettlement @relation(fields: [monthlySettlementId], references: [id], onDelete: Cascade)
  
  @@index([monthlySettlementId])
}

model CategorySplit {
  id         String   @id @default(cuid())
  categoryId String
  userId     String
  percentage Float    // Percentage (0-100) for this user
  
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
  
  @@unique([categoryId, userId])
  @@index([categoryId])
  @@index([userId])
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String
  userId    String
  amount    Float   // Exact amount this user should pay
  
  expense   Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id])
  
  @@unique([expenseId, userId])
  @@index([expenseId])
  @@index([userId])
}

enum SplitType {
  EQUAL    // Equal split among all active users
  CUSTOM   // Custom percentages per user
}

enum ExpenseType {
  EXPENSE
  CREDIT
}

enum SettlementStatus {
  OPEN
  CLOSED
}
