<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <rect width="512" height="512" fill="#1f2937" rx="64"/>
  <g fill="#ffffff">
    <!-- Calculator icon -->
    <rect x="128" y="96" width="256" height="320" rx="24" fill="#374151"/>
    <rect x="144" y="128" width="224" height="64" rx="8" fill="#1f2937"/>
    
    <!-- Display area -->
    <text x="256" y="172" text-anchor="middle" font-family="monospace" font-size="24" fill="#10b981">R$ 1.234,56</text>
    
    <!-- Buttons -->
    <rect x="160" y="216" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="216" y="216" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="272" y="216" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="328" y="216" width="40" height="32" rx="4" fill="#ef4444"/>
    
    <rect x="160" y="264" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="216" y="264" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="272" y="264" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="328" y="264" width="40" height="32" rx="4" fill="#10b981"/>
    
    <rect x="160" y="312" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="216" y="312" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="272" y="312" width="40" height="32" rx="4" fill="#6b7280"/>
    <rect x="328" y="312" width="40" height="32" rx="4" fill="#3b82f6"/>
    
    <!-- Text labels -->
    <text x="180" y="236" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">7</text>
    <text x="236" y="236" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">8</text>
    <text x="292" y="236" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">9</text>
    <text x="348" y="236" text-anchor="middle" font-family="sans-serif" font-size="10" fill="#ffffff">DEL</text>
    
    <text x="180" y="284" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">4</text>
    <text x="236" y="284" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">5</text>
    <text x="292" y="284" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">6</text>
    <text x="348" y="284" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">+</text>
    
    <text x="180" y="332" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">1</text>
    <text x="236" y="332" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">2</text>
    <text x="292" y="332" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">3</text>
    <text x="348" y="332" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#ffffff">=</text>
  </g>
  
  <!-- App title -->
  <text x="256" y="460" text-anchor="middle" font-family="sans-serif" font-size="16" font-weight="bold" fill="#ffffff">Gastos Apto</text>
</svg>